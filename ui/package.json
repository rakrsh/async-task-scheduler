{
  "name": "async-scheduler-dashboard",
  "version": "1.0.0",
  "description": "Dashboard for visualizing async task scheduler metrics",
  "private": true,
  "workspaces": [
    "server",
    "client"
  ],
  "scripts": {
    "start": "npm run start --workspace=server",
    "dev": "concurrently \"npm run dev --workspace=server\" \"npm run dev --workspace=client\"",
    "build": "npm run build --workspace=client",
    "test": "npm run test --workspace=server"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
